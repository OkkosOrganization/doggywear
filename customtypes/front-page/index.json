{
  "id": "front-page",
  "json": {
    "Main": {
      "share_image": {
        "type": "Image",
        "config": {
          "constraint": {
            "width": 1200,
            "height": 630
          },
          "thumbnails": [],
          "label": "Share image"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "single": "heading1",
          "label": "Title"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong",
          "label": "Description"
        }
      },
      "items": {
        "type": "Group",
        "config": {
          "fields": {
            "item": {
              "type": "Link",
              "config": {
                "select": "document",
                "customtypes": ["product", "illustration"],
                "label": "item",
                "placeholder": "Illustration or Product"
              }
            }
          },
          "label": "Items"
        }
      },
      "secondary_title": {
        "type": "StructuredText",
        "config": {
          "single": "heading2",
          "label": "Secondary title"
        }
      },
      "secondary_description": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph",
          "label": "Secondary description"
        }
      },
      "secondary_items": {
        "type": "Group",
        "config": {
          "fields": {
            "item": {
              "type": "Link",
              "config": {
                "select": "document",
                "customtypes": ["product"],
                "label": "item"
              }
            }
          },
          "label": "Secondary items"
        }
      },
      "instagram_title": {
        "type": "StructuredText",
        "config": {
          "single": "heading1,heading2,heading3,heading4,heading5,heading6",
          "label": "Instagram title"
        }
      }
    }
  },
  "label": "Front-page",
  "repeatable": false,
  "status": true,
  "format": "custom"
}
